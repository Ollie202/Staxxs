# Supabase credentials — copy this file to `.env` and fill in real values.
# Get them from Supabase → Project Settings → API. See SETUP-AUTH.md.
# The anon key is safe to expose in the browser (Row Level Security protects data).
# In production (Vercel / GitHub Actions), set these as environment variables/secrets
# instead of committing them.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
